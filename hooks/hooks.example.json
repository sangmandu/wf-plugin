{
  "description": "wf workflow guard hooks. Copy to hooks.json only after command and state handling are verified.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/skills/wf/user-interrupt.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/skills/wf/stop-guard.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
